generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
}

//_________________________________USER SCHEMA__________________________________________
model User {
  id                  String    @id @default(cuid())
  fullName            String
  email               String    @unique
  phone               String?   @unique
  passwordHash        String
  role                Role

  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  
  isEmailVerified     Boolean   @default(false)
  isPhoneVerified     Boolean   @default(false)

  emailOtpHash        String?
  emailOtpExpiresAt   DateTime?

  phoneOtpHash        String?
  phoneOtpExpiresAt   DateTime?

  otpAttempts         Int       @default(0)

  isActive            Boolean   @default(true)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  listings  Listing[]
  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}



//_________________________________LISTING SCHEMA__________________________________________
enum Purpose {
  SALE
  RENT
}

enum SizeUnit {
  MARLA
  KANAL
  SQFT
}

enum ListingStatus {
  PENDING_AI_REVIEW
  ACTIVE
  PAUSED
  DELETED
}

model Listing {
  id              String     @id @default(cuid())
  title           String
  category        String
  purpose         Purpose
  city            String
  locality        String
  size            Float
  sizeUnit        SizeUnit
  price           Float
  bedrooms        Int?
  bathrooms       Int?
  description     String
  images          String[]
  status          ListingStatus @default(PENDING_AI_REVIEW)
  originalDesc    String?
  aiEnhancedDesc  String?
  sellerId        String
  seller          User       @relation(fields: [sellerId], references: [id])
  viewCount       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("listings")
  @@index([city, category, purpose])
}